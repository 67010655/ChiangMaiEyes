# Local backend configuration. Keep real keys in backend/.env or Vercel env vars.
CORS_ORIGINS=http://localhost:5173,https://chiangmaieyes.vercel.app
GROQ_API_KEYS=
GROQ_MODEL=llama-3.3-70b-versatile
GISTDA_API_KEY=
NASA_FIRMS_MAP_KEY=

# healthchecks.io ping URL — refresh_snapshot.py pings this on every successful
# run; the service alerts you by email if no ping arrives for a while.
HEALTHCHECK_URL=

# Email proximity alerts — only used by refresh_snapshot.py (the Thailand
# refresh worker), never by the Vercel backend. All four must be set for
# alerts to send; leave blank to keep the feature disabled.
#   SUPABASE_SERVICE_ROLE_KEY: Supabase project → Settings → API → service_role
#   (NOT the anon/publishable key — this one bypasses Row Level Security so the
#   refresh script can read every subscriber's row)
#   RESEND_API_KEY: free at https://resend.com (3,000 emails/month)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
RESEND_FROM_EMAIL=ChiangMaiEyes <onboarding@resend.dev>
