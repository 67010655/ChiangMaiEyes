# Local frontend API target. Production sets this in Vercel.
VITE_API_BASE_URL=http://localhost:8000

# Optional: enables email alert subscriptions (magic-link login + pinned-location
# proximity alerts). Leave unset to hide the feature. Get these from your Supabase
# project → Settings → API.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key
